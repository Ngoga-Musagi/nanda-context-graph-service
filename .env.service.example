# Hosted decision-memory service (service/app.py) — env vars.
# Copy to .env for local runs; set the same as secrets on Railway.

# --- Store (Neo4j Aura Free in production) ---
# Leave NCG_NEO4J_URI unset to use the in-memory fallback store (good for local dev).
# For Aura, use the bolt+s:// URI from your AuraDB instance.
# NCG_NEO4J_URI=neo4j+s://<dbid>.databases.neo4j.io
NCG_NEO4J_USER=neo4j
# NCG_NEO4J_PASSWORD=<your-aura-password>

# --- Precedent ranking (hybrid) ---
# When OPENAI_API_KEY is set, precedent ranks by embeddings (text-embedding-3-small);
# otherwise it falls back to deterministic lexical ranking. The service runs either way.
# OPENAI_API_KEY=sk-...

# --- Server ---
# PORT is injected by Railway/Render/Fly; defaults to 7200 locally.
# PORT=7200
