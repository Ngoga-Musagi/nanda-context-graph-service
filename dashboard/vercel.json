{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://YOUR_SERVER_IP:7201/api/:path*" },
    { "source": "/federation/:path*", "destination": "http://YOUR_SERVER_IP:7201/federation/:path*" },
    { "source": "/health", "destination": "http://YOUR_SERVER_IP:7201/health" }
  ]
}
